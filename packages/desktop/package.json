{
  "name": "writlarge",
  "version": "0.1.0",
  "description": "Daily writing practice. Forward only.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder --mac",
    "dist:dir": "vite build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.writlarge.app",
    "productName": "WritLarge",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "identity": null
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  }
}
